SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
PORT=4000

# Last.fm — free API key at https://www.last.fm/api/account/create
# When set, enables real similarity scoring via track.getSimilar.
# Without it the app falls back to Spotify search-based matching.
LASTFM_API_KEY=your_lastfm_api_key_here
